        "probes": [
          { "index": 0, "value": 0.0 },
          { "index": 14, "value": 0.0 },
          { "index": 112, "value": 0.0 },
          { "index": 224, "value": 0.0 }
        ]
      }
    },
    {
      "name": "pipelineKeepsNonStopCommandPendingUntilConfirmed",
      "type": "pipeline",
      "confirmationsRequired": 3,
      "steps": [
        {
          "action": "process",
          "grid": { "kind": "filled", "value": 0.30 },
          "expectedDecision": { "command": "STRAIGHT", "reason": "path_found", "pathCells": 15 },
          "expectedState": { "command": "STOP", "changed": false, "pendingCommand": "STRAIGHT", "pendingCount": 1 }
        },
        {
          "action": "process",
          "grid": { "kind": "filled", "value": 0.30 },
          "expectedDecision": { "command": "STRAIGHT", "reason": "path_found", "pathCells": 15 },
          "expectedState": { "command": "STOP", "changed": false, "pendingCommand": "STRAIGHT", "pendingCount": 2 }
        },
        {
          "action": "process",
          "grid": { "kind": "filled", "value": 0.30 },
          "expectedDecision": { "command": "STRAIGHT", "reason": "path_found", "pathCells": 15 },
          "expectedState": { "command": "STRAIGHT", "changed": true, "pendingCommand": null, "pendingCount": 0 }
        }
      ]
    },
    {
      "name": "pipelineFailSafeStopInterruptsConfirmedNonStopCommand",
      "type": "pipeline",
      "confirmationsRequired": 3,
      "feedback": true,
      "steps": [
        {
          "action": "process",
          "grid": { "kind": "filled", "value": 0.30 },
          "expectedDecision": { "command": "STRAIGHT", "reason": "path_found", "pathCells": 15 },
          "expectedState": { "command": "STOP", "changed": false, "pendingCommand": "STRAIGHT", "pendingCount": 1 },
          "expectedFeedback": { "command": "STOP", "messageKey": "stop", "reason": "path_found", "changed": false, "forced": false, "spoken": false, "utteranceId": null, "pendingCommand": "STRAIGHT", "pendingCount": 1 }
        },
        {
          "action": "process",
          "grid": { "kind": "filled", "value": 0.30 },
          "expectedDecision": { "command": "STRAIGHT", "reason": "path_found", "pathCells": 15 },
          "expectedState": { "command": "STOP", "changed": false, "pendingCommand": "STRAIGHT", "pendingCount": 2 },
          "expectedFeedback": { "command": "STOP", "messageKey": "stop", "reason": "path_found", "changed": false, "forced": false, "spoken": false, "utteranceId": null, "pendingCommand": "STRAIGHT", "pendingCount": 2 }
        },
        {
          "action": "process",
          "grid": { "kind": "filled", "value": 0.30 },
          "expectedDecision": { "command": "STRAIGHT", "reason": "path_found", "pathCells": 15 },
          "expectedState": { "command": "STRAIGHT", "changed": true, "pendingCommand": null, "pendingCount": 0 },
          "expectedFeedback": { "command": "STRAIGHT", "messageKey": "go_straight", "reason": "path_found", "changed": true, "forced": false, "spoken": true, "utteranceId": "utterance-1", "pendingCommand": null, "pendingCount": 0 }
        },
        {
          "action": "failSafeStop",
          "reason": "low_confidence",
          "expectedDecision": { "command": "STOP", "reason": "low_confidence", "pathCells": 0 },
          "expectedState": { "command": "STOP", "changed": true, "pendingCommand": null, "pendingCount": 0 },
          "expectedFeedback": { "command": "STOP", "messageKey": "stop", "reason": "low_confidence", "changed": true, "forced": false, "spoken": true, "utteranceId": "utterance-2", "pendingCommand": null, "pendingCount": 0 }
        }
      ],
      "expectedSpoken": [
        { "message": "Go straight", "queueMode": "FLUSH", "utteranceId": "utterance-1" },
        { "message": "Stop", "queueMode": "FLUSH", "utteranceId": "utterance-2" }
      ]
    },
